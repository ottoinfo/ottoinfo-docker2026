# Hosts Info
NETWORK_NAME=ottoinfo
SERVER_NAME=ottoinfo
TOP_LEVEL_DOMAIN=local
SERVER_URL=${SERVER_NAME}.${TOP_LEVEL_DOMAIN}

# Docker Compose ENVs
TRAEFIK_NAME=traefik
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTP_PORT_FORWARD=8080
TRAEFIK_HTTPS_PORT=443
TRAEFIK_HTTPS_PORT_FORWARD=8443
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_DASHBOARD_PORT_FORWARD=9000
TRAEFIK_SUB_DOMAIN=dashboard
TRAEFIK_API_DASHBOARD=true
TRAEFIK_API_INSECURE=true
TRAEFIK_DASHBOARD_CREDENTIALS_FILE=
# username: admin | password: localdev1234
# > echo $(htpasswd -nb -B admin "localdev1234") | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_CREDENTIALS=admin:$$2y$$05$$fn.20LiVFVgCxjntSDPy0urXP2Gkqjjv.FVYlhdpR1gpTkF3SBhr6

# Error Pages
ERROR_NAME=traefik-error-pages
ERROR_HTTP_PORT_FORWARD=8060
ERROR_HTTP_PORT=8080
ERROR_SUB_DOMAIN=errors
ERROR_TEMPLATE=ghost

# WHO AM I
WHOAMI_NAME=whoami
WHOAMI_SUB_DOMAIN=whoami

# Container Specific
TZ=America/Los_Angeles
CLOUDFLARE_DNS_API_TOKEN=
CLOUDFLARE_DNS_USERNAME=

