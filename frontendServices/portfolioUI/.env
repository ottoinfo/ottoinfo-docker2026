# Project Location - Digital Ocean Path
UI_LOCAL_REPO=${HOME}/Sites/portfolio

# ENVs
NODE_ENV=production
UI_IMAGE=node
UI_IMAGE_VERSION=25-slim
UI_SERVICE_NAME=portfolio-ui
UI_SERVICE_PORT_FORWARD=3033
UI_SERVICE_PORT=3001
UI_DOCKERFILE=Dockerfile

# Portfolio ENV Files
NODEMON=false
APP_ENV=production # local | test | development | production
DOMAIN=com
NODE_PORT=3001
SITE_URL=http://${DOMAIN}:${NODE_PORT}

COOKIE_DOMAIN=ottoinfo.com
COOKIE_MAX_AGE=365
VISITOR_COOKIE_NAME=vc
