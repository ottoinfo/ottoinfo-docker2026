# Hosts Info
TZ=America/Los_Angeles
SERVER_NAME=ottoinfo
TOP_LEVEL_DOMAIN=local

# Vars
APP_ENV=development
NODE_ENV=development
DOCKER_COMPOSE_FILE=docker-compose.yaml # Create a unique file for your SETUP
DOCKER_INSTALL_SETUP=true # setup.sh -> BOOLEAN -> should we try to install Docker on your machine?
DOCKER_START=true
DOCKER_COMPOSE_OPTIONS='--detach' #

####### PROJECT - Docker Folder
PROJECT_PATH=${HOME}/Docker/ottoinfo # This is SPECIFIC for your machine, leave off trailing `/`

####### REPOSITORY / FOLDERS
FE_REPOSITORY=frontendServices
BE_REPOSITORY=backendServices

####### HOSTS
# All Server Names you want available ( used for SSL certs )
SERVER_NAMES='${SERVER_NAME}.${TOP_LEVEL_DOMAIN} *.${SERVER_NAME}.${TOP_LEVEL_DOMAIN}'

####### SSL Certificates
SSL_CERT_PATH=${PROJECT_PATH}/traefik-proxy/certs # Leave off trailing `/`
SSL_SERVER_URL=${SERVER_NAME}.${TOP_LEVEL_DOMAIN}

OTTOINFO_NETWORK_NAME=ottoinfo
OTTOINFO_NETWORK_DRIVER=bridge

####### Override Docker ENV's services
## This will pass into all services and you can override defaults in .env ###

# Traefik Services
SERVER_URL=${SERVER_NAME}.${TOP_LEVEL_DOMAIN}
TRAEFIK_API_DASHBOARD=true
TRAEFIK_API_INSECURE=true
TRAEFIK_SERVICE_NAME=traefik
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_SERVICE_URL="http://${TRAEFIK_SERVICE_NAME}:${TRAEFIK_DASHBOARD_PORT}/dashboard/"

ERROR_SERVICE_NAME=error-pages
ERROR_HTTP_PORT=8080
ERROR_SERVICE_URL="http://${ERROR_SERVICE_NAME}:${ERROR_HTTP_PORT}"

# Frontend Services | Ability to override Defaults
UI_SERVICE_NAME=portfolio-ui
UI_SERVICE_PORT=3001
UI_SERVICE_URL="http://${UI_SERVICE_NAME}:${UI_SERVICE_PORT}"
DOMAIN=http://localhost:${UI_SERVICE_PORT}
COOKIE_DOMAIN=ottoinfo
COOKIE_MAX_AGE=365
VISITOR_COOKIE_NAME=vc

# Docker Secrets - .TXT files located in `secrets` folder
# Uncomment once file created || use the .env file variables
CLOUDFLARE_DNS_API_TOKEN_FILE=/run/secrets/cloudflare_dns_api_token
CLOUDFLARE_DNS_USERNAME_FILE=/run/secrets/cloudflare_dns_username
GOOGLE_API_TOKEN_FILE= # /run/secrets/google_api
SENTRY_AUTH_TOKEN_FILE= # /run/secrets/sentry_auth_token
TRAEFIK_DASHBOARD_CREDENTIALS_FILE=/run/secrets/traefik_dashboard_credentials
